{
  "polyfillFiles": [
    "static/chunks/polyfills.js"
  ],
  "devFiles": [
    "static/chunks/react-refresh.js"
  ],
  "ampDevFiles": [
    "static/chunks/webpack.js",
    "static/chunks/amp.js"
  ],
  "lowPriorityFiles": [
    "static/development/_buildManifest.js",
    "static/development/_ssgManifest.js",
    "static/development/_middlewareManifest.js"
  ],
  "pages": {
    "/_app": [
      "static/chunks/webpack.js",
      "static/chunks/main.js",
      "static/chunks/pages/_app.js"
    ],
    "/_error": [
      "static/chunks/webpack.js",
      "static/chunks/main.js",
      "static/chunks/pages/_error.js"
    ],
    "/domedb": [
      "static/chunks/webpack.js",
      "static/chunks/main.js",
      "static/chunks/pages/domedb.js"
    ],
    "/domedb/[db]/clusters": [
      "static/chunks/webpack.js",
      "static/chunks/main.js",
      "static/chunks/pages/domedb/[db]/clusters.js"
    ],
    "/domedb/[db]/functions": [
      "static/chunks/webpack.js",
      "static/chunks/main.js",
      "static/chunks/pages/domedb/[db]/functions.js"
    ],
    "/domedb/[db]/media": [
      "static/chunks/webpack.js",
      "static/chunks/main.js",
      "static/chunks/pages/domedb/[db]/media.js"
    ],
    "/domedb/[db]/users": [
      "static/chunks/webpack.js",
      "static/chunks/main.js",
      "static/chunks/pages/domedb/[db]/users.js"
    ]
  },
  "ampFirstPages": []
}